---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { Image } from 'astro:assets';

// Importación de imágenes
import pfp from '../assets/pfp.webp';
import prisionero from '../assets/prisionero.jpg';
import portfolio from '../assets/portfolio.png';
---

<Layout title="Mori's Portfolio">
  
  <header>
    <div class="header-text">
      <h1 id="header-presentation">
        Hi I'm <span class="name">Mori</span> <span class="waving-hand">👋</span> <br> 
        And I'm a <span id="iam-display" class="name">Developer</span>
      </h1>
    </div>
    
    <Image 
      src={pfp} 
      alt="Mori Profile" 
      id="pfp" 
      width={400} 
      height={400}
    />
  </header>

  <section class="Projects">
    <hr>
    <h1>Projects</h1>

    <div class="projects-container">
      
      <ProjectCard 
        title="Juego del Prisionero"
        description="Simulación estratégica basada en la teoría de juegos. Analiza la psicología y la cooperación humana mediante algoritmos lógicos en Python."
        image={prisionero}
        repoLink="https://github.com/MoriitoDev/juego-prisionero"
        techIcons={['fa6-brands:python', 'fa6-brands:github']}
      />
 
      <ProjectCard 
        title="Portafolio Personal"
        description="Este mismo sitio web. Desarrollado con Astro para un rendimiento óptimo, maquetado con HTML semántico y estilizado con CSS moderno."
        image={portfolio}
        repoLink="https://github.com/MoriitoDev/Astro-Portfolio"
        linkLabel="Ver repositorio"
        techIcons={['simple-icons:astro', 'fa6-brands:html5', 'fa6-brands:css3-alt']}
      />

    </div>
  </section>

  <script>
    // 1. Animación del texto del header
    const iam = ["Developer", "Programmer", "Gamer"];
    const textElement = document.getElementById('iam-display');
    let x = 0;

    if (textElement) {
      setInterval(() => {
          textElement.classList.add("hide");
          setTimeout(() => {
            x++;
            if (x >= iam.length) x = 0;
            textElement.innerText = iam[x];
            textElement.classList.remove("hide");
          }, 500); 
      }, 3000);
    }

    // 2. Animación de Scroll (Intersection Observer)
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.scroll-animate').forEach((el) => observer.observe(el));
  </script>

</Layout>

<style>
  /* --- HEADER SECTION --- */
  header {
    display: flex;
    min-height: 80vh;
    width: 80vw;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    margin: 0 auto;
    gap: 3rem;
    padding: 2rem 0;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4.5em);
    margin: 0;
    line-height: 1.1;
  }

  .name {
    color: var(--ctp-lavender);
    display: inline-block; 
  }

  #pfp {
    border-radius: 50%;
    width: 20em;
    height: 20em;
    border: 0.3em solid var(--ctp-lavender);
    box-shadow: 0 0 30px var(--ctp-lavender);
    object-fit: cover;
  }

  /* --- PROJECTS SECTION --- */
  .Projects {
    text-align: center;
    width: 90vw;
    max-width: 1200px;
    margin: 8em auto;
  }

  .Projects h1 {
    margin: 0.5em 0;
    color: var(--ctp-teal);
  }

  .Projects hr {
    width: 30vw;
    margin: 0 auto;
    border-color: var(--ctp-overlay);
    opacity: 0.5;
  }

  .projects-container {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2.5rem;
    margin-top: 4rem;
  }

  #iam-display {
    opacity: 1;
    transform: translateY(0px);
    filter: blur(0px);
    transition: all 0.5s ease-in-out;
    width: 6em;
  }

  #iam-display.hide {
    opacity: 0;
    transform: translateY(10px);
    filter: blur(4px);
  }

  /* Waving hand animation */
  .waving-hand {
    display: inline-block;
    transform-origin: 70% 70%;
    margin-left: 10px;
    animation: wave-animation 2.5s infinite ease-in-out;
  }

  @keyframes wave-animation {
    0% { transform: rotate(0.0deg) }
    10% { transform: rotate(14.0deg) }
    20% { transform: rotate(-8.0deg) }
    30% { transform: rotate(14.0deg) }
    40% { transform: rotate(-4.0deg) }
    50% { transform: rotate(10.0deg) }
    60% { transform: rotate(0.0deg) }
    100% { transform: rotate(0.0deg) }
  }
</style>