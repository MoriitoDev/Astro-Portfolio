---
//npm install @iconify-json/logos For icon support
//npm install astro-icon For icon support
//npm install @iconify-json/skill-icons For icon support
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { Image } from 'astro:assets';
import SkillCard from '../components/SkillCard.astro';
import Footer from '../components/Footer.astro'
import { Icon } from 'astro-icon/components';

// Importación de imágenes
import pfp from '../assets/pfp.jpg';
import prisionero from '../assets/prisionero.jpg';
import portfolio from '../assets/portfolio.png';
import kuroz from '../assets/kuroz.png'
---

<Layout title="Mori's Portfolio">
  
  <header>
    <div class="header-text">
      <h1 id="header-presentation">
        Hi I'm Mori <span class="waving-hand">👋</span> <br> 
        And I'm a <span id="iam-display" class="name purple-gradient">Developer</span>
      </h1>

      <p class="desc-header">
  Full Stack Developer based in Córdoba. A Medac Arena student obsessed with continuous learning. I focus on building modern, functional websites while mastering new technologies every day.
      </p>

      <a href="https://github.com/MoriitoDev?tab=repositories" class="btn" target="_blank"> <Icon name={'fa6-brands:github'} /> View repositories</a>
      <a href="https://www.linkedin.com/in/rafa-c%C3%B3rdoba-zafra-3a4a8b396/" class="btn" target="_blank"> <Icon name={'fa6-brands:linkedin'} />Contact me</a>
    </div>
    
    <Image 
      src={pfp} 
      alt="Mori Profile" 
      id="pfp" 
      width={400} 
      height={400}
      fetchpriority="high"
    />
  </header>

  <section class="Projects">
    <hr>
    <h1>Projects</h1>

    <div class="projects-container">
      
      <ProjectCard 
        title="Juego del Prisionero"
        description="A strategic simulation based on Game Theory. It analyzes human psychology and cooperation dynamics through logical algorithms in Python."
        image={prisionero}
        repoLink="https://github.com/MoriitoDev/juego-prisionero"
        techIcons={['fa6-brands:python', 'fa6-brands:github']}
      />
 
      <ProjectCard 
        title="Portafolio Personal"
        description="This personal portfolio. Built with Astro for optimal performance, utilizing semantic HTML and modern CSS styling."
        image={portfolio}
        repoLink="https://github.com/MoriitoDev/Astro-Portfolio"
        linkLabel="View repository"
        techIcons={['simple-icons:astro', 'fa6-brands:html5', 'fa6-brands:css3-alt']}
      />

      <ProjectCard 
      title='KuroZ Bot'
      description='A collaborative Discord bot project featuring custom commands and utilities, developed with Python to enhance server interaction.'
      image={kuroz}
      repoLink='https://github.com/MoriitoDev/kuroz_development'
      linkLabel='View repository'
      techIcons={['simple-icons:discord', 'simple-icons:python']}

      />

    </div>
  </section>

  <section class="Skills">
    <hr>
    <h1>Skills</h1>

    <div class="skill-container">
      <SkillCard 
      title='FrontEnd'
      techIcons={['skill-icons:html', 'skill-icons:css', 'logos:javascript']}
      accentColor='#FF7A30'
      />

      <SkillCard 
      title='BackEnd'
      techIcons={['logos:python', 'logos:javascript', 'logos:java']}
      accentColor='#89dceb'
    />

    <SkillCard 
      title='Frameworks'
      techIcons={['logos:astro-icon', 'logos:nodejs-icon', 'logos:spring-icon', 'skill-icons:tailwindcss-dark']}
      accentColor='#a6e3a1'
    />
    </div>
  </section>

  <Footer />

  <script>
    // Animación del texto del header
    const iam = ["Developer", "Programmer", "Student"];
    const textElement = document.getElementById('iam-display');
    let x = 0;

    if (textElement) {
      setInterval(() => {
          textElement.classList.add("hide");
          setTimeout(() => {
            x++;
            if (x >= iam.length) x = 0;
            textElement.innerText = iam[x];
            textElement.classList.remove("hide");
          }, 500); 
      }, 3000);
    }

    // Animación de Scroll (Intersection Observer)
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.scroll-animate').forEach((el) => observer.observe(el));
  </script>

</Layout>

<style>
  /* --- HEADER SECTION --- */
  header {
    display: flex;
    min-height: 80vh;
    width: 80vw;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    margin: 0 auto;
    gap: 3rem;
    padding: 2rem 0;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4.5em);
    margin: 0;
    line-height: 1.1;
  }

  .name {
    display: inline-block;
  }

  #pfp {
    border-radius: 50%;
    width: 20em;
    height: 20em;
    border: 0.3em solid var(--ctp-lavender);
    box-shadow: 0 0 30px var(--ctp-lavender);
    object-fit: cover;
  }

  .desc-header {
    width: fit-content;
    font-weight: 550;
    font-size: 1.3em;
    margin-top: .5em;
    color: var(--ctp-subtext);
    width: 50vw;
  }

  .purple-gradient {
    background: linear-gradient(45deg, rgba(203, 166, 247, 1), rgba(137, 180, 250, 1));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }

  .btn {
    display: inline-block;
    font-size: 1.5em;
    color: var(--ctp-base);
    border: 2px solid var(--ctp-lavender);
    background-color: var(--ctp-lavender);
    border-radius: 8px;
    text-decoration: none;
    transition: ease 0.3s;
    text-align: center;
    margin-top: 1em;
    padding: 0.3em;
    font-weight: bold;
    margin-right: .8em;
  }

  .btn:hover {
    background-color: transparent;
    color: var(--ctp-text);
    border-color: var(--ctp-text);
  }
  .btn a {
    padding: 0.5em 1em;
    display: inline-block;
  }

  .btn [data-icon] {
    font-size: 1.5em;
    vertical-align: middle;
    margin-right: 0.15em;
  }



  /* --- PROJECTS SECTION --- */
  .Projects {
    text-align: center;
    width: 90vw;
    max-width: 1200px;
    margin: 8em auto;
  }

  /* --- PROJECTS SECTION --- */
  .Projects h1 {
    margin: 0.5em 0;
    color: var(--ctp-lavender);
  }

  .Projects hr {
    width: 30vw;
    margin: 0 auto;
    border-color: var(--ctp-overlay);
    opacity: 0.5;
  }

  .projects-container {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2.5rem;
    margin-top: 4rem;
  }

  .skill-container {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2.5rem;
    margin-top: 4rem;
  }

  #iam-display {
    opacity: 1;
    transform: translateY(0px);
    filter: blur(0px);
    transition: all 0.5s ease-in-out;
    width: 6em;
  }

  #iam-display.hide {
    opacity: 0;
    transform: translateY(10px);
    filter: blur(4px);
  }

  /* SKILLS */
  .Skills {
    text-align: center;
    width: 90vw;
    max-width: 1200px;
    margin: 8em auto;
  }

  /* --- PROJECTS SECTION --- */
  .Skills h1 {
    margin: 0.5em 0;
    color: var(--ctp-lavender);
  }

  .Skills hr {
    width: 30vw;
    margin: 0 auto;
    border-color: var(--ctp-overlay);
    opacity: 0.5;
  }

  /* Waving hand animation */
  .waving-hand {
    display: inline-block;
    transform-origin: 70% 70%;
    margin-left: 10px;
    animation: wave-animation 2.5s infinite ease-in-out;
  }

  @keyframes wave-animation {
    0% { transform: rotate(0.0deg) }
    10% { transform: rotate(14.0deg) }
    20% { transform: rotate(-8.0deg) }
    30% { transform: rotate(14.0deg) }
    40% { transform: rotate(-4.0deg) }
    50% { transform: rotate(10.0deg) }
    60% { transform: rotate(0.0deg) }
    100% { transform: rotate(0.0deg) }
  }

  /* Styles for the mini pfp*/

  #floating-pfp {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 60px;
    height: 60px;
    z-index: 100;
    opacity: 0;
    transform: translateY(20px) scale(0.8);
    pointer-events: none;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    cursor: pointer;
  }
</style>