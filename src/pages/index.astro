---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { Image } from 'astro:assets';
import SkillCard from '../components/SkillCard.astro';
import Footer from '../components/Footer.astro'

// Importación de imágenes
import pfp from '../assets/pfp.webp';
import prisionero from '../assets/prisionero.jpg';
import portfolio from '../assets/portfolio.png';
import kuroz from '../assets/kuroz.png'
---

<Layout title="Mori's Portfolio">
  
  <header>
    <div class="header-text">
      <h1 id="header-presentation">
        Hi I'm <span class="name">Mori</span> <span class="waving-hand">👋</span> <br> 
        And I'm a <span id="iam-display" class="name">Developer</span>
      </h1>
    </div>
    
    <Image 
      src={pfp} 
      alt="Mori Profile" 
      id="pfp" 
      width={400} 
      height={400}
      fetchpriority="high"
    />
  </header>

  <section class="Projects">
    <hr>
    <h1>Projects</h1>

    <div class="projects-container">
      
      <ProjectCard 
        title="Juego del Prisionero"
        description="Simulación estratégica basada en la teoría de juegos. Analiza la psicología y la cooperación humana mediante algoritmos lógicos en Python."
        image={prisionero}
        repoLink="https://github.com/MoriitoDev/juego-prisionero"
        techIcons={['fa6-brands:python', 'fa6-brands:github']}
      />
 
      <ProjectCard 
        title="Portafolio Personal"
        description="Este mismo sitio web. Desarrollado con Astro para un rendimiento óptimo, maquetado con HTML semántico y estilizado con CSS moderno."
        image={portfolio}
        repoLink="https://github.com/MoriitoDev/Astro-Portfolio"
        linkLabel="Ver repositorio"
        techIcons={['simple-icons:astro', 'fa6-brands:html5', 'fa6-brands:css3-alt']}
      />

      <ProjectCard 
      title='KuroZ Bot'
      description='Un bot de discord desarollado principalmente por mi con la colaboración de algunos amigos.'
      image={kuroz}
      repoLink='https://github.com/MoriitoDev/kuroz_development'
      linkLabel='Ver repositorio'
      techIcons={['simple-icons:discord', 'simple-icons:python']}

      />

    </div>
  </section>

  <section class="Skills">
    <hr>
    <h1>Skills</h1>

    <div class="skill-container">
      <SkillCard 
      title='FrontEnd'
      techIcons={['simple-icons:javascript', 'simple-icons:html5', 'simple-icons:css']}
      accentColor='#f9e2af'
      />

      <SkillCard 
      title='BackEnd'
      techIcons={['simple-icons:python', 'simple-icons:javascript', 'fa6-brands:java']}
      accentColor='#89dceb'
    />

    <SkillCard 
      title='Frameworks'
      techIcons={['simple-icons:astro', 'simple-icons:discorddotjs', 'simple-icons:springboot']}
      accentColor='#a6e3a1'
    />
    </div>
  </section>

  <Footer />

  <a href="#" id="floating-pfp">
  <Image 
    src={pfp} 
    alt="Mori Mini" 
    width={80} 
    height={80}
  />
  </a>

  <script>
    // Animación del texto del header
    const iam = ["Developer", "Programmer", "Gamer"];
    const textElement = document.getElementById('iam-display');
    let x = 0;

    if (textElement) {
      setInterval(() => {
          textElement.classList.add("hide");
          setTimeout(() => {
            x++;
            if (x >= iam.length) x = 0;
            textElement.innerText = iam[x];
            textElement.classList.remove("hide");
          }, 500); 
      }, 3000);
    }

    // Mini pfp para volver arriba
    const originalPFP = document.getElementById('pfp');
    const miniPFP = document.getElementById('floating-pfp')

    if (originalPFP && miniPFP) {
      const pfpObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) {
            miniPFP.classList.add('mipfp-show');
          }
          else {
            miniPFP.classList.remove('mipfp-show');
          }
        })
      })
      pfpObserver.observe(originalPFP)
    }

    // Animación de Scroll (Intersection Observer)
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.scroll-animate').forEach((el) => observer.observe(el));
  </script>

</Layout>

<style>
  /* --- HEADER SECTION --- */
  header {
    display: flex;
    min-height: 80vh;
    width: 80vw;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    margin: 0 auto;
    gap: 3rem;
    padding: 2rem 0;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4.5em);
    margin: 0;
    line-height: 1.1;
  }

  .name {
    color: var(--ctp-lavender);
    display: inline-block; 
  }

  #pfp {
    border-radius: 50%;
    width: 20em;
    height: 20em;
    border: 0.3em solid var(--ctp-lavender);
    box-shadow: 0 0 30px var(--ctp-lavender);
    object-fit: cover;
  }

  /* --- PROJECTS SECTION --- */
  .Projects {
    text-align: center;
    width: 90vw;
    max-width: 1200px;
    margin: 8em auto;
  }

  /* --- PROJECTS SECTION --- */
  .Projects h1 {
    margin: 0.5em 0;
    color: var(--ctp-lavender);
  }

  .Projects hr {
    width: 30vw;
    margin: 0 auto;
    border-color: var(--ctp-overlay);
    opacity: 0.5;
  }

  .projects-container {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2.5rem;
    margin-top: 4rem;
  }

  .skill-container {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2.5rem;
    margin-top: 4rem;
  }

  #iam-display {
    opacity: 1;
    transform: translateY(0px);
    filter: blur(0px);
    transition: all 0.5s ease-in-out;
    width: 6em;
  }

  #iam-display.hide {
    opacity: 0;
    transform: translateY(10px);
    filter: blur(4px);
  }

  /* SKILLS */
  .Skills {
    text-align: center;
    width: 90vw;
    max-width: 1200px;
    margin: 8em auto;
  }

  /* --- PROJECTS SECTION --- */
  .Skills h1 {
    margin: 0.5em 0;
    color: var(--ctp-lavender);
  }

  .Skills hr {
    width: 30vw;
    margin: 0 auto;
    border-color: var(--ctp-overlay);
    opacity: 0.5;
  }

  /* Waving hand animation */
  .waving-hand {
    display: inline-block;
    transform-origin: 70% 70%;
    margin-left: 10px;
    animation: wave-animation 2.5s infinite ease-in-out;
  }

  @keyframes wave-animation {
    0% { transform: rotate(0.0deg) }
    10% { transform: rotate(14.0deg) }
    20% { transform: rotate(-8.0deg) }
    30% { transform: rotate(14.0deg) }
    40% { transform: rotate(-4.0deg) }
    50% { transform: rotate(10.0deg) }
    60% { transform: rotate(0.0deg) }
    100% { transform: rotate(0.0deg) }
  }

  /* Styles for the mini pfp*/

  #floating-pfp {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 60px;
    height: 60px;
    z-index: 100;
    opacity: 0;
    transform: translateY(20px) scale(0.8);
    pointer-events: none;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    cursor: pointer;
  }
  

  #floating-pfp img {
    border-radius: 50%;
    width: 100%;
    height: 100%;
    border: 2px solid var(--ctp-lavender);
    box-shadow: 0 4px 15px rgba(0,0,0,0.3);
  }

  #floating-pfp.mipfp-show {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: all;
  }

  #floating-pfp:hover {
    transform: translateY(-5px) scale(1.1);
  }
</style>