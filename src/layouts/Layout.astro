---
import '@fontsource/outfit/400.css';
import '@fontsource/outfit/700.css';
import '@fontsource/jetbrains-mono/400.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="Portafolio de desarrollo de Mori" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--ctp-crust: #11111b;
		--ctp-base: #1e1e2e;
		--ctp-text: #cdd6f4;
		--ctp-subtext: #a6adc8;
		--ctp-lavender: #b4befe;
		--ctp-mauve: #cba6f7;
		--ctp-surface: #313244;
		--ctp-overlay: #45475a;
		--ctp-pink: #f5c2e7;
		--ctp-teal: #94e2d5;
		--ctp-sapphire: #74c7ec;
		--ctp-yellow: #f9e2af;
		
		--font-main: 'Outfit', sans-serif;
		--font-mono: 'JetBrains Mono', monospace;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
		scroll-behavior: smooth;
	}

	body {
		background: linear-gradient(180deg,rgba(30, 30, 46, 1) 0%, rgba(17, 17, 27, 1) 100%);
		color: var(--ctp-text);
		font-family: var(--font-main);
		line-height: 1.6;
		-webkit-font-smoothing: antialiased;
		overflow-x: hidden;
	}
</style>