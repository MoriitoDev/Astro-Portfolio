---
import { User, Code2, Terminal, Sparkles, Linkedin, Github } from '@lucide/astro'
import Image from 'astro/components/Image.astro'
import pfp from '../assets/pfp.jpg'
---

<section id="about" class="min-h-screen flex items-center justify-center py-20 px-6 animate-fade-in">
  <div class="max-w-6xl w-full grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
    
    <div class="relative group justify-self-center md:justify-self-start">
      <div class="absolute -inset-4 bg-pine-rose/20 rounded-2xl blur-xl group-hover:bg-pine-rose/30 transition duration-500"></div>
      <div class="relative bg-pine-surface border border-pine-overlay p-2 rounded-2xl shadow-2xl overflow-hidden">
        <Image 
          src={pfp}
          alt="Rafa Córdoba" 
          class="w-64 h-64 md:w-80 md:h-80 object-cover rounded-xl bg-pine-base"
        />
      </div>
      
      <div class="absolute -bottom-6 -right-6 bg-pine-gold p-4 rounded-lg shadow-xl rotate-12 group-hover:rotate-0 transition-transform duration-300">
        <Sparkles class="size-8 text-pine-base" />
      </div>

      <div class="absolute -top-6 -left-6 bg-pine-pine p-4 rounded-lg shadow-xl -rotate-12 group-hover:rotate-0 transition-transform duration-300">
        <a href="https://www.linkedin.com/in/rafa-c%C3%B3rdoba-zafra-3a4a8b396/" target="_blank"><Linkedin class="size-8 text-pine-base" /></a>
        <a href="https://github.com/MoriitoDev" target="_blank"><Github class="size-8 text-pine-base mt-2" /></a>

      </div>
    </div>

    <div class="flex flex-col gap-6">
      <div class="space-y-2">
        <h3 class="font-kalam text-pine-foam text-2xl">Who am I?</h3>
        <h2 class="font-inspiration text-pine-text text-7xl leading-none">About Me</h2>
      </div>

      <p class="font-kalam text-pine-text/80 text-lg leading-relaxed">
        I'm a passionate <span class="text-pine-rose font-bold">Fullstack Developer</span> based in Spain. 
        I love turning complex problems into simple, beautiful, and intuitive designs. 
        When I'm not coding, you'll probably find me exploring new technologies or 
        polishing my pixel-perfect interfaces.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
        <div class="p-4 bg-pine-surface/50 border border-pine-overlay rounded-xl hover:border-pine-foam/50 transition-colors">
          <Code2 class="size-6 text-pine-foam mb-2" />
          <h4 class="font-bold text-pine-text">Frontend</h4>
          <p class="text-sm text-pine-text/60">React, Astro, Tailwind</p>
        </div>
        
        <div class="p-4 bg-pine-surface/50 border border-pine-overlay rounded-xl hover:border-pine-gold/50 transition-colors">
          <Terminal class="size-6 text-pine-gold mb-2" />
          <h4 class="font-bold text-pine-text">Backend</h4>
          <p class="text-sm text-pine-text/60">Node.js, Python, Java, SQL</p>
        </div>
      </div>

      <div class="mt-4">
        <a href="#projects" class="inline-flex items-center gap-2 text-pine-foam font-bold hover:underline decoration-pine-rose underline-offset-4">
          Check my technical skills 
          <span class="text-xl">→</span>
        </a>
      </div>

      
    </div>

  </div>
</section>

<style>
  /* Animación de entrada suave al hacer scroll */
  #about {
    view-timeline-name: --section;
    view-timeline-axis: block;
    animation-timeline: --section;
    animation-name: reveal;
    animation-range: entry 10% cover 30%;
    animation-fill-mode: both;
  }

  @keyframes reveal {
    from { opacity: 0; transform: translateY(50px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>