---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  repoLink: string;
  linkLabel?: string; 
  techIcons: string[];
}

const { 
  title, 
  description, 
  image, 
  repoLink, 
  linkLabel = "Ver repositorio", 
  techIcons 
} = Astro.props;
---

<article class="project-card scroll-animate">
  <div class="card-image">
    <Image src={image} alt={`Imagen del proyecto ${title}`} width={600} />
  </div>

  <div class="card-content">
    <div class="card-header">
      <h2>{title}</h2>
      <div class="tech-stack">
        {techIcons.map((icon) => (
          <Icon name={icon} />
        ))}
      </div>
    </div>
    
    <p>{description}</p>
    
    <a href={repoLink} target="_blank" class="card-link">
      {linkLabel} &rarr;
    </a>
  </div>
</article>

<style>
  .project-card {
    background-color: var(--ctp-surface);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--ctp-overlay);
    display: flex;
    flex-direction: column;
    width: 380px;
    max-width: 90vw;
    transition: 0.3s ease;
    text-align: left;
  }

  /* Estilos para la tarjeta entera */
  .project-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 0 30px var(--ctp-mauve);
  }

  .card-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .project-card:hover .card-image img {
    transform: scale(1.05);
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex-grow: 1;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .card-header h2 {
    font-size: 1.5rem;
    margin: 0;
    color: var(--ctp-mauve);
    font-family: var(--font-mono);
    line-height: 1.2;
  }

  .tech-stack {
    display: flex;
    gap: 8px;
  }

  .tech-stack [data-icon] {
    width: 1.8rem;
    height: 1.8rem;
    color: var(--ctp-subtext);
    transition: color 0.3s, transform 0.3s;
  }

  .project-card:hover .tech-stack [data-icon] {
    color: var(--ctp-pink);
    transform: translateY(-2px);
  }

  .card-content p {
    font-size: 0.95rem;
    color: var(--ctp-subtext);
    margin: 0;
    line-height: 1.6;
  }

  .card-link {
    margin-top: auto;
    text-decoration: none;
    color: var(--ctp-pink);
    font-weight: bold;
    font-size: 1.2rem;
    display: inline-block;
    transition: opacity 0.2s;
  }

  .card-link:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  .scroll-animate {
    opacity: 0;
    transform: translateY(50px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  :global(.scroll-animate.visible) {
    opacity: 1;
    transform: translateY(0);
  }
</style>